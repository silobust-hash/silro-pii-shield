{
  "name": "silro-pii-shield",
  "version": "0.6.0",
  "description": "한국 노무사·변호사를 위한 AI 입력 PII 자동 가명화 Chrome 확장",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "lint": "tsc --noEmit",
    "icons": "node scripts/export-icons.mjs",
    "audit": "npm audit",
    "audit:fix": "npm audit fix",
    "build:zip": "npm run build && cd dist && zip -r ../silro-pii-shield-v1.0.0.zip . && cd .."
  },
  "devDependencies": {
    "@crxjs/vite-plugin": "^2.0.0",
    "@playwright/test": "^1.45.0",
    "@resvg/resvg-js": "^2.6.2",
    "@types/chrome": "^0.0.270",
    "@types/node": "^20.14.0",
    "happy-dom": "^20.9.0",
    "typescript": "^5.5.0",
    "vite": "^5.3.0",
    "vite-plugin-static-copy": "^4.1.0",
    "vitest": "^1.6.0"
  },
  "dependencies": {
    "docx": "^9.6.1",
    "jszip": "^3.10.1",
    "mammoth": "^1.12.0",
    "pdfjs-dist": "^5.7.284",
    "tesseract.js": "^5.1.1",
    "xlsx": "^0.18.5"
  }
}
